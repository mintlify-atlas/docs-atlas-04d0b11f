  "keyFeatures": [
    "Real-time event monitoring and notifications",
    "Multi-channel alert delivery (Discord, Telegram, Email, WhatsApp)",
    "Customizable event categories with emojis and colors",
    "Analytics dashboard with event tracking and filtering",
    "Tiered subscription plans (Free, Pro, Enterprise)",
    "API key authentication for secure event ingestion",
    "Quota management based on subscription tier",
    "Event history and delivery status tracking"
