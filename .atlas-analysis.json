  "publicApiSurface": [
    "POST /api/v1/event - Send event notification",
    "GET /api/category/getEventCategories - List event categories",
    "POST /api/category/createEventCategory - Create event category",
    "DELETE /api/category/deleteCategory - Delete event category",
    "GET /api/category/getEventsByCategoryName - Get events by category",
    "GET /api/category/pollCategory - Poll category for events",
    "POST /api/category/insertQuickstartCategories - Create quickstart categories",
    "GET /api/auth/user - Get current user",
    "POST /api/payment/createCheckoutSession - Create Stripe checkout session"
  ]
